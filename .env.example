# NimAgent environment template — copy to `.env` and fill in your own keys.
# The real `.env` is git-ignored and stays on your machine; this example is the
# only one committed. Values here override settings.json; a real shell env var
# overrides the file. Keys are per-provider: NIMAGENT_<PROVIDER>_KEY.

# NVIDIA NIM (default provider) — free key at https://build.nvidia.com
NIMAGENT_NVIDIA_KEY=

# Other OpenAI-compatible providers (only set the ones you use)
NIMAGENT_OPENAI_KEY=
NIMAGENT_OPENROUTER_KEY=

# Optional: override the config directory
# NIMAGENT_HOME=
