{
  "name": "nimagent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "NimAgent - a from-scratch terminal coding agent (pi/claude-cli style) for OpenAI-compatible providers",
  "author": "Erik Boivin <erik.boivin@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/tattooinmtl/nimagent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tattooinmtl/nimagent.git"
  },
  "bugs": {
    "url": "https://github.com/tattooinmtl/nimagent/issues"
  },
  "bin": {
    "NimAgent": "./bin/nimagent.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node ./bin/nimagent.mjs",
    "test": "node ./test-tools.mjs",
    "setup": "node ./scripts/setup.mjs",
    "setup:router": "node ./scripts/setup.mjs --with-router",
    "zip:source": "git archive --worktree-attributes --format=zip --output dist/nimagent-source.zip HEAD",
    "install:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./install/install.ps1 -SkipRepoUpdate",
    "install:update": "powershell -NoProfile -ExecutionPolicy Bypass -File ./install/install.ps1 -AutoUpdate"
  }
}
