{
  "$schema": "./schema/nimagent.config.schema.json",
  "promptFile": "prompts/default.md",
  "theme": "themes/forge-yellow.json",
  "extensions": [
    "extensions/file-tools.js",
    "extensions/web-search.js"
  ],
  "skills": [
    "skills/code-review",
    "skills/project-doctor",
    "skills/html-game-builder",
    "skills/vs-project-starter"
  ],
  "autoDiscoverSkills": true,
  "registry": "https://globalwarningnetworks.com/repo",
  "mcpServers": {},
  "mcp": {
    "idleTimeout": 10,
    "directTools": false
  },
  "router": {
    "enabled": false,
    "mode": "auto",
    "default": "coding",
    "python": {
      "interpreter": "python",
      "confidenceThreshold": 0.60,
      "timeoutMs": 150
    }
  },
  "bridge": {
    "enabled": false,
    "hermesRoot": "C:\\hermes-agent",
    "python": {
      "interpreter": "python"
    }
  }
}
